{
  "cesp_version": "1.0",
  "name": "stronghold-saladin",
  "display_name": "Saladin (Stronghold Crusader)",
  "version": "1.0.0",
  "author": { "name": "Marko Jevic", "github": "koyev" },
  "license": "fair-use",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "sounds/sa_add_player_01.wav", "label": "Welcome" }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        { "file": "sounds/sa_willattack_01.wav", "label": "This is wise" },
        { "file": "sounds/sa_sent_01.wav", "label": "Goods will be sent" },
        { "file": "sounds/sa_siege_01.wav", "label": "Walls will fall to dust" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "sounds/sa_vict_01.wav", "label": "No match for my forces" },
        { "file": "sounds/sa_boast_01.wav", "label": "Dispatched another enemy" },
        { "file": "sounds/sa_vict_04.wav", "label": "Another has fallen" }
      ]
    },
    "task.error": {
      "sounds": [
        { "file": "sounds/sa_anger_01.wav", "label": "You fight too well" },
        { "file": "sounds/sa_anger_02.wav", "label": "Thorn in my side" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "sounds/sa_help_01.wav", "label": "Grave danger" },
        { "file": "sounds/sa_plead_01.wav", "label": "At your mercy" },
        { "file": "sounds/sa_req_01.wav", "label": "Have need of supplies" }
      ]
    },
    "resource.limit": {
      "sounds": [
        { "file": "sounds/sa_notsent_01.wav", "label": "Need goods myself" },
        { "file": "sounds/sa_nohelp_01.wav", "label": "Futile act" }
      ]
    },
    "user.spam": {
      "sounds": [
        { "file": "sounds/sa_noattack_01.wav", "label": "Most unwise" },
        { "file": "sounds/sa_kick_player_01.wav", "label": "Farewell" }
      ]
    }
  }
}
